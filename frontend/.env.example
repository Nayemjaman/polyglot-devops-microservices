# Browser requests use same-origin Next.js rewrites by default, which avoids CORS in dev.
# Set this only if you intentionally want the browser to call the gateway directly.
# NEXT_PUBLIC_API_BASE_URL=http://localhost:8080

# Used by Next.js rewrites to proxy /auth/* and /api/* to the backend gateway.
API_PROXY_TARGET=http://localhost:8080
TRANSACTION_API_TARGET=http://localhost:8002
REPORT_API_TARGET=http://localhost:8003
BUDGET_API_TARGET=http://localhost:8001
