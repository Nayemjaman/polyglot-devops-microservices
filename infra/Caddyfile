{
	admin 0.0.0.0:2019
	auto_https disable_redirects
	servers {
		metrics
	}
}

http://:8080 {
	encode gzip

	header {
		X-Content-Type-Options "nosniff"
		X-Frame-Options "DENY"
		Referrer-Policy "no-referrer"
	}

	handle /auth/* {
		reverse_proxy {$AUTH_SERVICE_UPSTREAM:auth-service}:8000
	}

	handle /api/budgets* {
		reverse_proxy {$BUDGET_SERVICE_UPSTREAM:budget-service}:8001
	}

	handle /api/reports* {
		reverse_proxy {$REPORT_SERVICE_UPSTREAM:report-service}:8003
	}

	handle /api/* {
		reverse_proxy {$TRANSACTION_SERVICE_UPSTREAM:transaction-service}:8002
	}

	handle /status/transaction/* {
		uri strip_prefix /status/transaction
		reverse_proxy {$TRANSACTION_SERVICE_UPSTREAM:transaction-service}:8002
	}

	handle /status/report/* {
		uri strip_prefix /status/report
		reverse_proxy {$REPORT_SERVICE_UPSTREAM:report-service}:8003
	}

	handle /status/budget/* {
		uri strip_prefix /status/budget
		reverse_proxy {$BUDGET_SERVICE_UPSTREAM:budget-service}:8001
	}

	handle /health {
		respond "ok" 200
	}

	handle {
		reverse_proxy {$FRONTEND_UPSTREAM:frontend}:3000
	}
}

https://localhost:8443, https://127.0.0.1:8443 {
	tls internal
	encode gzip

	header {
		Strict-Transport-Security "max-age=31536000; includeSubDomains"
		X-Content-Type-Options "nosniff"
		X-Frame-Options "DENY"
		Referrer-Policy "no-referrer"
	}

	handle /auth/* {
		reverse_proxy {$AUTH_SERVICE_UPSTREAM:auth-service}:8000
	}

	handle /api/budgets* {
		reverse_proxy {$BUDGET_SERVICE_UPSTREAM:budget-service}:8001
	}

	handle /api/reports* {
		reverse_proxy {$REPORT_SERVICE_UPSTREAM:report-service}:8003
	}

	handle /api/* {
		reverse_proxy {$TRANSACTION_SERVICE_UPSTREAM:transaction-service}:8002
	}

	handle /status/transaction/* {
		uri strip_prefix /status/transaction
		reverse_proxy {$TRANSACTION_SERVICE_UPSTREAM:transaction-service}:8002
	}

	handle /status/report/* {
		uri strip_prefix /status/report
		reverse_proxy {$REPORT_SERVICE_UPSTREAM:report-service}:8003
	}

	handle /status/budget/* {
		uri strip_prefix /status/budget
		reverse_proxy {$BUDGET_SERVICE_UPSTREAM:budget-service}:8001
	}

	handle /health {
		respond "ok" 200
	}

	handle {
		reverse_proxy {$FRONTEND_UPSTREAM:frontend}:3000
	}
}
