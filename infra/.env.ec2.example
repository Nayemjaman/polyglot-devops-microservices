DOCKERHUB_USER_NAME=your-dockerhub-username
IMAGE_TAG=main

AUTH_DJANGO_SECRET_KEY=change-me-to-a-long-random-secret
AUTH_DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,auth-service,your-ec2-public-dns-or-domain
AUTH_CORS_ALLOWED_ORIGINS=http://your-ec2-public-dns-or-domain:8080
AUTH_DB_PASSWORD=change-me

BUDGET_DB_PASSWORD=change-me
BUDGET_GRPC_SHARED_SECRET=change-me

REPORT_DB_PASSWORD=change-me
REPORT_GRPC_SHARED_SECRET=change-me

TRANSACTION_DB_PASSWORD=change-me
TRANSACTION_GRPC_SHARED_SECRET=change-me
TRANSACTION_STORAGE_ACCESS_KEY=change-me
TRANSACTION_STORAGE_SECRET_KEY=change-me
TRANSACTION_STORAGE_PUBLIC_BASE_URL=http://your-ec2-public-dns-or-domain:8080

RABBITMQ_DEFAULT_USER=app
RABBITMQ_DEFAULT_PASS=change-me
