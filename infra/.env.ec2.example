DOCKERHUB_USER_NAME=your-dockerhub-username
FRONTEND_IMAGE_TAG=frontend-main
AUTH_SERVICE_IMAGE_TAG=auth-service-main
BUDGET_SERVICE_IMAGE_TAG=budget-service-main
REPORT_SERVICE_IMAGE_TAG=report-service-main
TRANSACTION_SERVICE_IMAGE_TAG=transaction-service-main

FRONTEND_ACTIVE_COLOR=blue
AUTH_SERVICE_ACTIVE_COLOR=blue
BUDGET_SERVICE_ACTIVE_COLOR=blue
REPORT_SERVICE_ACTIVE_COLOR=blue
TRANSACTION_SERVICE_ACTIVE_COLOR=blue

FRONTEND_UPSTREAM=frontend
AUTH_SERVICE_UPSTREAM=auth-service
BUDGET_SERVICE_UPSTREAM=budget-service
REPORT_SERVICE_UPSTREAM=report-service
TRANSACTION_SERVICE_UPSTREAM=transaction-service

AUTH_DJANGO_SECRET_KEY=change-me-to-a-long-random-secret
AUTH_DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,auth-service,auth-service-blue,auth-service-green,your-ec2-public-dns-or-domain
AUTH_CORS_ALLOWED_ORIGINS=http://your-ec2-public-dns-or-domain:8080
AUTH_REFRESH_COOKIE_SECURE=false
AUTH_DB_PASSWORD=change-me

BUDGET_DB_PASSWORD=change-me
BUDGET_GRPC_SHARED_SECRET=change-me

REPORT_DB_PASSWORD=change-me
REPORT_GRPC_SHARED_SECRET=change-me

TRANSACTION_DB_PASSWORD=change-me
TRANSACTION_GRPC_SHARED_SECRET=change-me
TRANSACTION_STORAGE_ACCESS_KEY=change-me
TRANSACTION_STORAGE_SECRET_KEY=change-me
TRANSACTION_STORAGE_PUBLIC_BASE_URL=http://your-ec2-public-dns-or-domain:8080

RABBITMQ_DEFAULT_USER=app
RABBITMQ_DEFAULT_PASS=change-me
