APP_NAME=transaction-service
APP_ENV=development
HOST=0.0.0.0
PORT=8002
AUTH_SERVICE_URL=http://127.0.0.1:8000
HTTP_TIMEOUT_SECONDS=5
DATABASE_URL=postgresql+asyncpg://transaction_service_user:transaction_service_password@127.0.0.1:6435/transaction_service_db
DATABASE_ECHO=False
DATABASE_POOL_SIZE=5
DATABASE_MAX_OVERFLOW=10
STORAGE_ENDPOINT_URL=http://127.0.0.1:9000
STORAGE_REGION=us-east-1
STORAGE_ACCESS_KEY=transaction_service_access_key
STORAGE_SECRET_KEY=transaction_service_secret_key
STORAGE_BUCKET_NAME=transaction-attachments
STORAGE_PUBLIC_BASE_URL=http://127.0.0.1:9000
STORAGE_PATH_PREFIX=attachments
